// NEGATE — involution. a = -a.
import Vm.State as S

module Vm.Instructions.Negate {
  fn forward(a: ref String) -{S.VmState}-> () {
    let av = S.read_reg(a);
    S.write_reg(a, -av)
  }
  fn backward(a: ref String) -{S.VmState}-> () {
    forward(a)
  }
}
