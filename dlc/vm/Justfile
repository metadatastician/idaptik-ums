set shell := ["bash", "-uc"]
import? "contractile.just"

default:
    @just --list --unsorted

bootstrap:
    asdf install
    opam install -y dune sedlex menhir ppx_deriving cmdliner yojson

build:
    affinescript compile --target wasmgc --module-per-file -o dist/wasm/ src/Vm.affine

test:
    affinescript test tests/

properties:
    affinescript test tests/properties/

clean:
    rm -rf dist target _build

container:
    podman build -t ghcr.io/hyperpolymath/idaptik-dlc-vm:latest -f Containerfile .

container-stapeln:
    stapeln build --target production

# Exit code propagates when trufflehog runs; a missing tool is a loud
# skip, never a silent pass (the old `|| true` swallowed real findings).
secret-scan-trufflehog:
    @if command -v trufflehog >/dev/null; then \
        trufflehog filesystem . --only-verified; \
    else \
        echo "trufflehog not installed — scan SKIPPED (not a pass)"; \
    fi
