# --- Zig FFI (ffi/zig) build output ---
zig-out/
.zig-cache/
zig-cache/

# Idris2 build output
build/

# Python bytecode. Nothing in this repo produces it any more (the engine and
# the DLC validator are Rust); kept so a stray local run cannot re-commit it (cpython-313
# pycs are tracked from before — untracking them is separate hygiene, this just
# stops new ones)
__pycache__/
*.pyc

# Python bytecode (the Python sources themselves are removed in the Rust migration).
__pycache__/
*.pyc

# Rust build artefacts
/target/
