{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/metadatastician/universal-modding-studio/blob/main/schemas/puzzle.schema.json",
  "title": "IDApTIK reversible-VM puzzle",
  "description": "One authored puzzle for the 23-instruction reversible VM (dlc/vm). Two formats exist: the standard register puzzle (initial state -> goal state under an instruction whitelist) and the vault sequence (a scripted chain of reversible ops over named bits). Cross-field invariants the schema language cannot express \u2014 initialState and goalState sharing one key set, optimalMoves <= maxMoves \u2014 are enforced by the `ums-dlc` crate.",
  "oneOf": [
    {
      "$ref": "#/$defs/registerPuzzle"
    },
    {
      "$ref": "#/$defs/vaultSequence"
    }
  ],
  "$defs": {
    "instruction": {
      "enum": [
        "ADD",
        "AND",
        "CALL",
        "DIV",
        "FLIP",
        "IFPOS",
        "IFZERO",
        "LOAD",
        "LOOP",
        "MUL",
        "NEGATE",
        "NOOP",
        "OR",
        "POP",
        "PUSH",
        "RECV",
        "ROL",
        "ROR",
        "SEND",
        "STORE",
        "SUB",
        "SWAP",
        "XOR"
      ],
      "description": "Uppercase name of one of the VM's 23 instructions (dlc/vm/src/instructions/)."
    },
    "registerState": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "integer"
      },
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "registerPuzzle": {
      "type": "object",
      "required": [
        "name",
        "description",
        "difficulty",
        "initialState",
        "goalState",
        "maxMoves",
        "optimalMoves",
        "allowedInstructions",
        "hints",
        "metadata"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "difficulty": {
          "enum": [
            "beginner",
            "intermediate",
            "advanced",
            "expert"
          ]
        },
        "initialState": {
          "$ref": "#/$defs/registerState"
        },
        "goalState": {
          "$ref": "#/$defs/registerState"
        },
        "maxMoves": {
          "type": "integer",
          "minimum": 1
        },
        "optimalMoves": {
          "type": "integer",
          "minimum": 1
        },
        "allowedInstructions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/instruction"
          }
        },
        "hints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "moveNumber",
              "text"
            ],
            "additionalProperties": false,
            "properties": {
              "moveNumber": {
                "type": "integer",
                "minimum": 0
              },
              "text": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "required": [
            "author",
            "created",
            "tags"
          ],
          "additionalProperties": false,
          "properties": {
            "author": {
              "type": "string"
            },
            "created": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "license": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        }
      }
    },
    "vaultSequence": {
      "type": "object",
      "required": [
        "name",
        "description",
        "state",
        "steps"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          },
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "op"
            ],
            "additionalProperties": false,
            "properties": {
              "op": {
                "enum": [
                  "flip",
                  "xor",
                  "swap"
                ]
              },
              "target": {
                "type": "string"
              },
              "targets": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 2,
                "maxItems": 2
              },
              "result": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
